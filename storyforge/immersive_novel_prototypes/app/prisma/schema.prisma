
generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/immersive_novel_prototypes/app/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User progress and saves
  progress     UserProgress[]
  feedback     Feedback[]
  achievements Achievement[]

  @@map("users")
}

model UserProgress {
  id            String   @id @default(cuid())
  userId        String
  prototypeId   String
  sceneId       String
  choices       Json     @default("{}")
  currentState  Json     @default("{}")
  lastAccessed  DateTime @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, prototypeId])
  @@map("user_progress")
}

model Feedback {
  id          String      @id @default(cuid())
  userId      String?
  prototypeId String
  rating      Int
  categories  Json        @default("{}")
  comment     String?
  feedbackType FeedbackType
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedback")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  prototypeId String
  type        String
  name        String
  description String
  unlockedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

enum FeedbackType {
  PROTOTYPE_SPECIFIC
  OVERALL_EXPERIENCE
  ACCESSIBILITY
  TECHNICAL_ISSUE
}
